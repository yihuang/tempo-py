# tempo-devnet configuration
# ==========================
# Copy and customize this file to run a local multi-node Tempo testnet.
#
# Usage:
#   tempo-devnet serve --data ./data --config ./devnet.yaml

# Chain ID (default: 1337)
chain_id: 1337

# Number of prefunded accounts (default: 10000)
accounts: 10000

# Epoch length in blocks (default: 100)
epoch_length: 100

# Block gas limit (default: 500000000)
gas_limit: 500000000

# Mnemonic for deterministic account generation
# (default: "test test test test test test test test test test test junk")
mnemonic: "test test test test test test test test test test test junk"

# Fixed seed for deterministic key generation (omit for random)
seed: 42

# Hardfork activation timestamps (Unix seconds; 0 = active at genesis)
# t0_time: 0
# t1_time: 0
# t2_time: 0
# t3_time: 0
# t4_time: 0
# t5_time: 0
# t6_time: 0
# t7_time: 0
# t8_time: 0

# Disable initial DKG in genesis (for dev mode)
# no_dkg_in_genesis: false

# Disable creating Alpha/Beta/ThetaUSD tokens
# no_extra_tokens: false

# Disable minting pairwise FeeAMM liquidity
# no_pairwise_liquidity: false

# Path to the tempo binary (default: "tempo")
# tempo_bin: tempo

# Path to the tempo-xtask binary (default: "tempo-xtask")
# tempo_xtask_bin: tempo-xtask

# Validator definitions
# Each validator gets a base_port. Service ports are derived as:
#   +0 consensus P2P (--consensus.listen-address)
#   +1 execution P2P (--port / --discovery.port)
#   +2 consensus metrics (--consensus.metrics-address)
#   +3 engine API authrpc (--authrpc.port)
#   +4 HTTP JSON-RPC (--http.port)
#   +5 WebSocket (--ws.port)
#
# Network topology:
# - ``host``: advertised IP for trusted-peers and metrics (default: 127.0.0.1)
# - ``p2p_host``: IP to bind the consensus P2P listener (default: same as ``host``)
#   Set to ``0.0.0.0`` to accept external P2P connections (for public bootnodes).
# - ``rpc_host``: IP to bind HTTP/WS JSON-RPC (default: ``0.0.0.0``)
#   External full nodes can sync via ``--follow ws://<host>:<ws_port>``.
#
# Private validator network (P2P on localhost, RPC on all interfaces):
#   host: 127.0.0.1
#   p2p_host: 127.0.0.1   # private — only other validators on same host can connect
#   rpc_host: 0.0.0.0     # public — external full nodes can follow via WS
#
# Public bootnode (P2P reachable from external full nodes):
#   host: <public-ip-or-dns>  # advertised address other nodes can dial
#   p2p_host: 0.0.0.0         # bind on all interfaces
#   rpc_host: 0.0.0.0
validators:
  - host: 127.0.0.1
    port: 8000
    moniker: node0
  - host: 127.0.0.1
    port: 8010
    moniker: node1
  - host: 127.0.0.1
    port: 8020
    moniker: node2
  - host: 127.0.0.1
    port: 8030
    moniker: node3

# ---------------------------------------------------------------------------
# Docker settings (optional — only used with --gen-compose-file)
# ---------------------------------------------------------------------------
# Each validator runs in its own container with a static IP on ``subnet`` so
# the consensus peer addresses baked into genesis (``<static_ip>:8000``) are
# reachable across containers.  HTTP/WS RPC is published to the host at
# ``base_port + 4/5``; P2P stays inside the Docker network.
# docker:
#   image: ghcr.io/tempoxyz/tempo:latest   # Official Tempo image for validators
#   network: tempo-devnet                  # Docker bridge network name
#   subnet: 10.88.0.0/24                   # Bridge subnet; validator i gets host octet 10+i

# ---------------------------------------------------------------------------
# Config patches — applied after ``tempo-xtask generate-localnet`` finishes
# ---------------------------------------------------------------------------

# Patch genesis.json (deep-merged, overrides any field).
# Use this to tweak chain config after generation.
# patch_genesis:
#   config:
#     extra_fields:
#       epochLength: 50
#   nonce: "0x42"
#   difficulty: "0x0"

# Patch reth.toml (written into each node's data directory).
# Controls reth's own config (p2p, db, rpc, etc).
# patch_reth:
#   p2p:
#     max_inbound: 50
#   db:
#     max_size: "8TB"

# Extra CLI flags passed to every ``tempo node`` invocation.
# Each entry is a separate argument (not shell-quoted as a whole).
# patch_node_flags:
#   - "--txpool.max-tempo-authorizations"
#   - "32"
#   - "--txpool.aa-valid-after-max-secs"
#   - "600"
